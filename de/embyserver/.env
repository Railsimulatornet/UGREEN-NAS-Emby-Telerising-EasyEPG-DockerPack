# =========================================================
# Emby + Telerising + EasyEPG - Projektvariablen (Docker Compose)
# Datei: .env  (liegt im gleichen Ordner wie docker-compose.yaml)
# Copyright Roman Glos 28.01.2026
# =========================================================

# --- Allgemein ---
TZ=Europe/Berlin

# Host-Pfade (bitte an deine NAS/Server-Struktur anpassen)
DOCKER_DIR=/volume2/docker/embyserver
MEDIA_DIR=/volume1/Emby
EMBY_BACKUP_DIR=/volume3/dockersich/EmbySicherung
EMBY_SYSTEM_DIR=/volume2/EmbySystem

# --- Linuxserver/SWAG (Reverse Proxy) ---
PUID=1000
PGID=10

SWAG_URL=example.com
SWAG_SUBDOMAINS=emby
SWAG_ONLY_SUBDOMAINS=true
SWAG_EMAIL=mail@example.com
SWAG_FAIL2BAN_ENABLED=true

# --- Emby Container (emby/embyserver) ---
EMBY_UID=1000
EMBY_GID=10
# Diese GIDLIST benötigt man für die Hardwaretranscodierung
EMBY_GIDLIST=44,105
EMBY_UMASK=002

# --- EasyEPG ---
USER_ID=1000
GROUP_ID=10
EASYEPG_UPDATE=yes
EASYEPG_REPO=script.service.easyepg-lite
EASYEPG_BRANCH=main
EASYEPG_PYTHONPATH=/easyepg/pylibs

# --- Telerising ---
TELERISING_UID=1000
TELERISING_GID=10
TELERISING_UPDATE=yes

# --- Ports (Host -> Container) ---
# Emby
# 8096/TCP = Emby Web UI/API (HTTP)
EMBY_PORT_HTTP=8096

# 7359/UDP = Emby Auto-Discovery im LAN (optional)
EMBY_PORT_DISCOVERY_UDP=7359

# Emby Port HTTPS ist abgeschaltet, weil wir dies mit SWAG umsetzen.
# EMBY_PORT_HTTPS=8920

# SWAG Ports
# 5080->80  = HTTP (intern)
# 50443->443 = HTTPS (intern)
# 8920->8920 = eigener Listener für Emby-SSL über SWAG
SWAG_PORT_HTTP=5080
SWAG_PORT_HTTPS=50443
SWAG_PORT_EMBY_SSL=8920
SWAG_PORT_DASH=58080

# EasyEPG / Telerising
EASYEPG_PORT=4000
TELERISING_PORT=5000
