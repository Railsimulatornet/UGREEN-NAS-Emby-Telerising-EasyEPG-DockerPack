# =========================================================
# Emby + Telerising + EasyEPG - project variables (Docker Compose)
# File: .env (must be in the same folder as docker-compose.yaml)
# Copyright Roman Glos 28.01.2026
# =========================================================

# --- General ---
TZ=Europe/Berlin

# Host paths (adjust to your NAS/server layout)
DOCKER_DIR=/volume2/docker/embyserver
MEDIA_DIR=/volume1/Emby
EMBY_BACKUP_DIR=/volume3/dockersich/EmbySicherung
EMBY_SYSTEM_DIR=/volume2/EmbySystem

# --- LinuxServer/SWAG (reverse proxy) ---
PUID=1000
PGID=10

SWAG_URL=example.com
SWAG_SUBDOMAINS=emby
SWAG_ONLY_SUBDOMAINS=true
SWAG_EMAIL=mail@example.com
SWAG_FAIL2BAN_ENABLED=true

# --- Emby container (emby/embyserver) ---
EMBY_UID=1000
EMBY_GID=10
# This GIDLIST is required for hardware transcoding
EMBY_GIDLIST=44,105
EMBY_UMASK=002

# --- EasyEPG ---
USER_ID=1000
GROUP_ID=10
EASYEPG_UPDATE=yes
EASYEPG_REPO=script.service.easyepg-lite
EASYEPG_BRANCH=main
EASYEPG_PYTHONPATH=/easyepg/pylibs

# --- Telerising ---
TELERISING_UID=1000
TELERISING_GID=10
TELERISING_UPDATE=yes

# --- Ports (host -> container) ---
# Emby
# 8096/TCP = Emby Web UI/API (HTTP)
EMBY_PORT_HTTP=8096

# 7359/UDP = Emby auto-discovery on the LAN (optional)
EMBY_PORT_DISCOVERY_UDP=7359

# Emby HTTPS port is disabled because TLS is handled by SWAG.
# EMBY_PORT_HTTPS=8920

# SWAG ports
# 5080->80   = HTTP (internal)
# 50443->443 = HTTPS (internal)
# 8920->8920 = dedicated listener for Emby SSL via SWAG
SWAG_PORT_HTTP=5080
SWAG_PORT_HTTPS=50443
SWAG_PORT_EMBY_SSL=8920
SWAG_PORT_DASH=58080

# EasyEPG / Telerising
EASYEPG_PORT=4000
TELERISING_PORT=5000
